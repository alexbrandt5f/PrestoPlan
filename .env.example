# ============================================================================
# PrestoPlan Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it contains secrets.
# ============================================================================

# Supabase — your project's API URL and anonymous (public) key.
# Find these in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry — error tracking DSN (Data Source Name).
# Find in: Sentry Dashboard → Settings → Projects → Your Project → Client Keys
# Leave blank to disable error tracking in local development.
VITE_SENTRY_DSN=

# App version — used as Sentry release tag for correlating errors with deploys.
# Netlify can inject this automatically via build settings.
# Leave blank for local dev.
VITE_APP_VERSION=
